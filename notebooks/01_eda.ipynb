   "source": [
    "type_failure = df.groupby('Type')['Machine failure'].agg(['sum', 'count'])\n",
    "type_failure['failure_rate'] = (type_failure['sum'] / type_failure['count'] * 100).round(2)\n",
    "print(type_failure)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7, 4))\n",
    "bars = ax.bar(type_failure.index, type_failure['failure_rate'],\n",
    "              color=['#4C9BE8', '#F5A623', '#E8614C'],\n",
    "              edgecolor='white', linewidth=1.2)\n",
    "ax.bar_label(bars, fmt='%.1f%%', padding=4, fontsize=11)\n",
    "ax.set_title('Failure Rate by Product Type', fontsize=14)\n",
    "ax.set_xlabel('Product Type (H=High, M=Medium, L=Low quality)')\n",
    "ax.set_ylabel('Failure Rate (%)')\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reports/figures/09_failure_by_type.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
