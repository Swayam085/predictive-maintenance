    "fig, ax = plt.subplots(figsize=(9, 6))\n",
    "normal = df[df['Machine failure'] == 0]\n",
    "failure = df[df['Machine failure'] == 1]\n",
    "\n",
    "ax.scatter(normal['Rotational speed [rpm]'], normal['Torque [Nm]'],\n",
    "           alpha=0.3, s=10, color='#4C9BE8', label='Normal')\n",
    "ax.scatter(failure['Rotational speed [rpm]'], failure['Torque [Nm]'],\n",
    "           alpha=0.8, s=25, color='#E8614C', label='Failure', zorder=5)\n",
    "\n",
    "ax.set_title('Rotational Speed vs Torque', fontsize=14)\n",
    "ax.set_xlabel('Rotational Speed [rpm]')\n",
    "ax.set_ylabel('Torque [Nm]')\n",
    "ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reports/figures/08_speed_vs_torque.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
