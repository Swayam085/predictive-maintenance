    "# Failure types breakdown\n",
    "failure_cols = ['TWF', 'HDF', 'PWF', 'OSF', 'RNF']\n",
    "failure_counts = df[failure_cols].sum().sort_values(ascending=False)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 5))\n",
    "bars = ax.bar(failure_counts.index, failure_counts.values,\n",
    "              color=['#E8614C', '#4C9BE8', '#F5A623', '#7ED321', '#9B9B9B'],\n",
    "              edgecolor='white', linewidth=1.2)\n",
    "ax.bar_label(bars, fmt='%d', padding=4, fontsize=11)\n",
    "ax.set_title('Failure Types Distribution', fontsize=14, pad=12)\n",
    "ax.set_xlabel('Failure Type')\n",
    "ax.set_ylabel('Count')\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reports/figures/05_failure_types.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
