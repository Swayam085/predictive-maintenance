    "df['Temp_diff'] = df['Process temperature [K]'] - df['Air temperature [K]']\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 5))\n",
    "\n",
    "axes[0].hist(df[df['Machine failure']==0]['Temp_diff'], \n",
    "             bins=30, color='#4C9BE8', edgecolor='white', alpha=0.8)\n",
    "axes[0].set_title('Temp Difference — Normal', fontsize=11)\n",
    "axes[0].set_xlabel('Process - Air Temp [K]')\n",
    "\n",
    "axes[1].hist(df[df['Machine failure']==1]['Temp_diff'], \n",
    "             bins=30, color='#E8614C', edgecolor='white', alpha=0.8)\n",
    "axes[1].set_title('Temp Difference — Failure', fontsize=11)\n",
    "axes[1].set_xlabel('Process - Air Temp [K]')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reports/figures/07_temp_difference.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
