   "source": [
    "df = pd.read_csv('../data/raw/ai4i2020.csv')\n",
    "\n",
    "print(\"Shape:\", df.shape)\n",
    "print(\"\\nColumns:\", df.columns.tolist())\n",
    "print(\"\\nNull Values:\\n\", df.isnull().sum())\n",
    "print(\"\\nTarget Distribution:\\n\", df['Machine failure'].value_counts())"
   ]
  },
