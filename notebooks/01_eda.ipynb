   "source": [
    "import plotly.express as px\n",
    "\n",
    "fig = px.scatter(df, \n",
    "                 x='Rotational speed [rpm]', \n",
    "                 y='Torque [Nm]',\n",
    "                 color='Machine failure',\n",
    "                 color_discrete_map={0: '#4C9BE8', 1: '#E8614C'},\n",
    "                 title='Interactive: Rotational Speed vs Torque',\n",
    "                 hover_data=['Type', 'Tool wear [min]'],\n",
    "                 opacity=0.6)\n",
    "fig.write_html('../reports/figures/10_interactive_speed_torque.html')\n",
    "fig.show()"
   ]
  },
