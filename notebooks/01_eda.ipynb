    "fig, ax = plt.subplots(figsize=(8, 6))\n",
    "scatter = ax.scatter(df['Air temperature [K]'],\n",
    "                     df['Process temperature [K]'],\n",
    "                     c=df['Machine failure'],\n",
    "                     cmap='coolwarm', alpha=0.5, s=15)\n",
    "plt.colorbar(scatter, ax=ax, label='Machine Failure')\n",
    "ax.set_title('Air vs Process Temperature', fontsize=14)\n",
    "ax.set_xlabel('Air Temperature [K]')\n",
    "ax.set_ylabel('Process Temperature [K]')\n",
    "plt.tight_layout()\n",
    "plt.savefig('../reports/figures/06_temperature_scatter.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
